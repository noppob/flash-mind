# FlashMind environment variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets — .env*.local is gitignored.

# --- Database (Prisma) -------------------------------------------------------
# Default: PostgreSQL (Neon).
#   DATABASE_URL は pooled URL (-pooler ホスト) に ?pgbouncer=true&connection_limit=1 を付ける
#   DIRECT_URL は pooler を経由しない direct URL（prisma migrate / introspect 用）
DATABASE_URL="postgresql://USER:PWD@ep-xxx-pooler.region.neon.tech/flashmind?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PWD@ep-xxx.region.neon.tech/flashmind?sslmode=require"

# オフライン開発用に SQLite を使いたい場合（prisma/sqlite/schema.prisma 経由）:
#   DATABASE_URL=file:./dev.db で上書きし、`pnpm db:generate:sqlite` で Client を切替
#   DIRECT_URL は無視される
# DATABASE_URL="file:./dev.db"

# --- Auth.js v5 --------------------------------------------------------------
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` で生成
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# 将来追加: OAuth プロバイダ
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

# --- AI ----------------------------------------------------------------------
# OpenAI API（Chat = カード生成 / 辞書 / 翻訳、Whisper = Podcast 書き起こし）
# 取得: https://platform.openai.com/api-keys
# /api/ai/* と /api/imports で必須（未設定時は 503 を返す）
# モデルは lib/openai.ts の AI_MODEL / WHISPER_MODEL で集中管理
OPENAI_API_KEY=
