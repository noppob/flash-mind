# FlashMind environment variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets — .env*.local is gitignored.

# --- Database (Prisma) -------------------------------------------------------
# Dev (SQLite): file:./dev.db
# Prod (Postgres / Neon): postgresql://user:pwd@host/db?sslmode=require
DATABASE_URL="file:./dev.db"

# Postgres を使う場合の direct 接続 (prisma migrate 用)
# DIRECT_URL=

# --- Auth.js v5 --------------------------------------------------------------
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` で生成
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# 将来追加: OAuth プロバイダ
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

# --- AI ----------------------------------------------------------------------
# Anthropic Claude API
# 取得: https://console.anthropic.com/ → API Keys → Create Key
# /api/ai/* と /api/imports で必須（未設定時は 503 を返す）
ANTHROPIC_API_KEY=
