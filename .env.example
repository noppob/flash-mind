# FlashMind environment variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets — .env*.local is gitignored.

# --- Backend (TBD) -----------------------------------------------------------
# Supabase を採用する場合の例
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# 自前 API + Postgres を採用する場合の例
# DATABASE_URL=postgresql://user:password@localhost:5432/flashmind

# --- AI ----------------------------------------------------------------------
# Anthropic Claude API (例文生成・解説などに利用予定)
# ANTHROPIC_API_KEY=

# --- Auth (TBD) --------------------------------------------------------------
# AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
